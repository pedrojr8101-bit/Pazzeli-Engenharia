// Schema do banco — MVP: site institucional + simulação + captura de lead
// As próximas fases (área do cliente, área admin, proposta em PDF) vão
// reaproveitar o modelo Simulacao já com todos os dados técnicos calculados.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum StatusLead {
  NOVO
  CONTATADO
  PROPOSTA_ENVIADA
  CONVERTIDO
  PERDIDO
}

enum GrupoTarifario {
  A
  B
}

enum TipoLigacao {
  MONOFASICO
  BIFASICO
  TRIFASICO
}

// Residencial x Comercial — usado no dashboard admin para comparar conversão
// e faturamento entre os dois perfis de imóvel.
enum TipoImovel {
  RESIDENCIAL
  COMERCIAL
}

// Chamado de pós-venda aberto pelo cliente (limpeza, manutenção etc).
enum TipoChamado {
  LIMPEZA
  MANUTENCAO
  REVISAO_TECNICA
  OUTRO
}

enum StatusChamado {
  ABERTO
  EM_ANDAMENTO
  CONCLUIDO
  CANCELADO
}

model AdminUser {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senhaHash String
  createdAt DateTime @default(now())
}

model Lead {
  id         String      @id @default(cuid())
  nome       String
  email      String
  telefone   String
  cep        String
  cidade     String?
  uf         String?
  origem     String?
  status     StatusLead  @default(NOVO)
  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  simulacoes Simulacao[]

  senhaHash     String?
  solarzPlantId Int?

  tipoImovel TipoImovel?

  contratoUrl String?

  chamados Chamado[]

  @@index([email])
  @@index([status])
}

model Simulacao {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  cep             String
  grupoTarifario  GrupoTarifario
  tipoLigacao     TipoLigacao?
  consumoMedioKwh Float
  tarifaKwh       Float

  latitude  Float?
  longitude Float?
  cidade    String?
  uf        String?

  hspMedioAnual Float
  hspMensal     Json

  potenciaNecessariaKwp Float
  potenciaInstaladaKwp  Float
  numeroPaineis         Int
  potenciaPainelW       Int
  geracaoMensalKwh      Float
  geracaoAnualKwh       Float
  classificacaoGD       String

  percentualFioBAno         Float
  fatorSimultaneidade       Float
  custoFioBMensal           Float
  custoDisponibilidadeMensal Float

  economiaMensalEstimada Float
  economiaAnualEstimada  Float
  investimentoEstimado   Float
  paybackAnos            Float?

  investimentoFinal   Float?
  observacoesProposta String?
  itensProposta       Json?
  tipoEstrutura       String?
  margemLucroPercentual Float?
  valorServico        Float?

  clienteCpf               String?
  clienteEnderecoCompleto  String?

  createdAt DateTime @default(now())

  @@index([leadId])
}

model Chamado {
  id     String @id @default(cuid())
  leadId String
  lead   Lead   @relation(fields: [leadId], references: [id], onDelete: Cascade)

  tipo      TipoChamado
  descricao String

  status       StatusChamado @default(ABERTO)
  valorCobrado Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([leadId])
  @@index([status])
}


