# Banco de dados (PostgreSQL — ex: Vercel Postgres, Neon, Supabase)
DATABASE_URL="postgresql://usuario:senha@host:5432/banco?sslmode=require"

# Nome/identidade da empresa (usados no site institucional)
NEXT_PUBLIC_EMPRESA_NOME="Nome da Empresa"
NEXT_PUBLIC_EMPRESA_TELEFONE="(00) 00000-0000"
NEXT_PUBLIC_EMPRESA_EMAIL="contato@empresa.com.br"

# Custo médio de instalação por kWp, usado como estimativa no simulador (R$/kWp)
NEXT_PUBLIC_CUSTO_MEDIO_KWP="3800"
